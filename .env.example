# =============================================================================
# Root / API (apps/api) - copy to .env in repo root or apps/api for local dev
# =============================================================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/botarena"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-me-to-a-long-random-string-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=4000
NODE_ENV=development
COOKIE_DOMAIN=localhost

# =============================================================================
# Web (apps/web) - copy to apps/web/.env.local
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws
# Required for Auth.js (NextAuth). Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-long-random-string-in-production
